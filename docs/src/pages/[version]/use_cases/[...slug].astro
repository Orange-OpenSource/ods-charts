---
import type { InferGetStaticPropsType } from 'astro'
import { render } from 'astro:content'
import UseCasesLayout from '@layouts/UseCasesLayout.astro';
import { useCasesPages, getDocsPageSlug } from '@libs/content'
import { getConfig } from '@libs/config'

export async function getStaticPaths() {
  return useCasesPages.map((docsPage) => {
    return {
      params: { slug: getDocsPageSlug(docsPage.id), version: getConfig().docs_version },
      props: docsPage
    }
  })
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>

const { data } = Astro.props
const { Content } = await render(Astro.props)
---

<UseCasesLayout data={data}>
  <Content />
</UseCasesLayout>
