---
import type { InferGetStaticPropsType } from 'astro'
import { render } from 'astro:content';
import ExamplesLayout from '@layouts/ExamplesLayout.astro';
import { examplesPages, getDocsPageSlug } from '@libs/content'
import { getConfig } from '@libs/config'

export async function getStaticPaths() {
  return examplesPages.map((docsPage) => {
    return {
      params: { slug: getDocsPageSlug(docsPage.id), version: getConfig().docs_version },
      props: docsPage
    }
  })
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>

const { data } = Astro.props
const { Content } = await render(Astro.props)
---

<ExamplesLayout data={data}>
  <Content />
</ExamplesLayout>
